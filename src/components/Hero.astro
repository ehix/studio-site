---
// Hero: name, one-line positioning, and the signature cube. The cube module
// is dynamically imported once the hero is on screen and the main thread is
// idle — the same load-when-visible behaviour as a client:visible island,
// without shipping a framework runtime. The inline SVG sketch is the static
// state: no JS, no WebGL, or reduced data all keep it.
import { SITE } from '../config/site';
---

<section aria-labelledby="hero-heading" class="py-16">
  <p class="tracking-label text-step--1 uppercase" aria-hidden="true">
    // {SITE.shortName.toLowerCase()}
  </p>
  <h1 id="hero-heading" class="text-step-4 mt-4 font-bold">{SITE.name}</h1>
  <p class="text-step-1 mt-4 max-w-[var(--measure-prose)]">{SITE.tagline}</p>

  <figure id="hero-cube" class="relative mt-12 aspect-square w-full max-w-sm">
    {/* Static fallback: the cube as an ink sketch. Hidden once WebGL mounts. */}
    <svg
      id="hero-cube-fallback"
      viewBox="0 0 200 200"
      class="absolute inset-0 h-full w-full"
      role="img"
      aria-label="A stone cube sketched in ink, pitted like porous rock"
    >
      <g stroke="var(--ink)" stroke-width="1.5" stroke-linejoin="bevel">
        <polygon points="100,22 168,58 100,94 32,58" fill="var(--paper-raised)"></polygon>
        <polygon points="32,58 100,94 100,178 32,142" fill="var(--paper)"></polygon>
        <polygon points="168,58 100,94 100,178 168,142" fill="var(--paper-raised)"></polygon>
      </g>
      {/* Stipple: the porosity, sketched. */}
      <g fill="var(--stone)">
        <circle cx="86" cy="46" r="2"></circle>
        <circle cx="118" cy="60" r="1.4"></circle>
        <circle cx="100" cy="38" r="1.2"></circle>
        <circle cx="70" cy="58" r="1.6"></circle>
        <circle cx="132" cy="48" r="1.1"></circle>
        <circle cx="50" cy="90" r="1.8"></circle>
        <circle cx="66" cy="118" r="1.3"></circle>
        <circle cx="46" cy="132" r="1.2"></circle>
        <circle cx="82" cy="140" r="2.2"></circle>
        <circle cx="60" cy="152" r="1.1"></circle>
        <circle cx="122" cy="112" r="1.9"></circle>
        <circle cx="140" cy="132" r="1.3"></circle>
        <circle cx="152" cy="96" r="1.5"></circle>
        <circle cx="118" cy="148" r="1.2"></circle>
        <circle cx="136" cy="160" r="1.6"></circle>
      </g>
      <g fill="var(--ink)" opacity="0.55">
        <circle cx="108" cy="52" r="1.1"></circle>
        <circle cx="58" cy="104" r="1.3"></circle>
        <circle cx="74" cy="128" r="0.9"></circle>
        <circle cx="130" cy="122" r="1.1"></circle>
        <circle cx="148" cy="146" r="0.9"></circle>
      </g>
    </svg>
    <figcaption class="sr-only">
      A cube of porous stone. Drag to spin it.
    </figcaption>
  </figure>
</section>

<script>
  const mount = document.getElementById('hero-cube');

  const boot = () => {
    const start = async () => {
      const { initHeroCube } = await import('../scripts/hero-cube');
      if (initHeroCube(mount!)) {
        document.getElementById('hero-cube-fallback')?.setAttribute('hidden', '');
      }
    };
    // Defer past first paint; the cube is seasoning, not the meal.
    'requestIdleCallback' in window
      ? requestIdleCallback(() => void start(), { timeout: 2000 })
      : setTimeout(() => void start(), 200);
  };

  if (mount) {
    new IntersectionObserver((entries, observer) => {
      if (entries.some((entry) => entry.isIntersecting)) {
        observer.disconnect();
        boot();
      }
    }).observe(mount);
  }
</script>
