---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 — page not found" description="Page not found.">
  <section class="py-16">
    <p class="tracking-label text-step--1 uppercase" aria-hidden="true">// 404</p>
    <h1 class="text-step-4 mt-4 font-bold">Page not found</h1>
    <p class="mt-4 max-w-[var(--measure-prose)]">
      Nothing here. <a href="/" class="hover:text-ember underline transition-colors duration-150"
        >Back to the front page</a
      >.
    </p>
  </section>
</BaseLayout>
